{
  "name": "moment-of-creation",
  "version": "0.9.0",
  "description": "A first-paint web animation: a First (a CSS firework birth) and a Last (a binary merger that resolves into a neon Form) combine into a Together. Drop it in as an isolated iframe/web-component embed, a full-page mount, or one self-contained .html — zero dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "Chris Portka",
  "homepage": "https://cportka.github.io/moment-of-creation/",
  "repository": { "type": "git", "url": "git+https://github.com/cportka/moment-of-creation.git" },
  "bugs": { "url": "https://github.com/cportka/moment-of-creation/issues" },
  "keywords": [
    "animation",
    "canvas",
    "css",
    "web-component",
    "custom-element",
    "first-paint",
    "intro",
    "loading-animation",
    "hero",
    "generative",
    "neon",
    "zero-dependency"
  ],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public", "provenance": true },
  "main": "./dist/moment-of-creation.umd.cjs",
  "module": "./dist/moment-of-creation.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/moment-of-creation.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/moment-of-creation.umd.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "first.html",
    "last.html",
    "together.html",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json && node -e \"require('fs').copyFileSync('src/engine/standalone.d.ts','dist/engine/standalone.d.ts')\" && node scripts/emit-cjs-types.mjs",
    "test": "vitest run",
    "export": "node scripts/export-animation.mjs",
    "build:pages": "node scripts/export-animation.mjs first first.html && node scripts/export-animation.mjs last last.html && node scripts/export-animation.mjs together together.html",
    "prepare": "npm run build:lib",
    "prepublishOnly": "npm test && tsc --noEmit",
    "verify:intro": "node scripts/verify-intro.mjs",
    "capture:creation": "node scripts/capture-creation.mjs",
    "capture:splash": "node scripts/capture-splash.mjs"
  },
  "devDependencies": {
    "@types/node": "^22",
    "jsdom": "^25",
    "typescript": "^5",
    "vite": "^7",
    "vitest": "^3"
  }
}
